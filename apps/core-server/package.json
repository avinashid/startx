{
	"name": "core-server",
	"description": "",
	"version": "1.0.0",
	"type": "module",

	"scripts": {
		"dev": "tsx watch src/index.ts",
		"dev:debug": "tsx watch --inspect src/index.ts",
		"bun:dev": "bun --watch src/index.ts",
		"build": "tsdown --config-loader unrun",
		"start": "node dist/index.mjs",
		"lint": "eslint .",
		"lint:fix": "eslint . src/**/*.ts --fix",
		"clean": "rimraf dist .turbo dist",
		"deep:clean": "rimraf node_modules dist .turbo",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"format:check": "biome ci .",
		"test": "vitest run"
	},
	"dependencies": {
		"@repo/constants": "workspace:^",
		"@repo/db": "workspace:^",
		"@repo/mail": "workspace:^",
		"@repo/lib": "workspace:^",
		"@repo/redis": "workspace:^",
		"@repo/env": "workspace:^",
		"@repo/logger": "workspace:^",
		"cookie-parser": "catalog:",
		"cors": "catalog:",
		"country-state-city": "catalog:",
		"express": "catalog:",
		"express-fileupload": "catalog:",
		"express-list-endpoints": "catalog:",
		"morgan": "catalog:"
	},
	"devDependencies": {
		"@types/cookie-parser": "catalog:",
		"@types/cors": "catalog:",
		"@types/express": "catalog:",
		"@types/express-fileupload": "catalog:",
		"@types/morgan": "catalog:",
		"eslint-config": "workspace:*",
		"vitest-config": "workspace:*",
		"tsdown-config": "workspace:*",
		"typescript-config": "workspace:*"
	},
	"startx": {
		"gTags": [
			"node",
			"backend"
		],
		"tags": [
			"dev"
		],
		"requiredDeps": [
			"@repo/env",
			"@repo/logger"
		],
		"requiredDevDeps": [
			"typescript-config",
			"tsdown-config"
		]
	}
}
