{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"lint": {
			"cache": true,
			"inputs": ["src/**", "eslint.config.*", ".eslintrc.*", "tsdown.config.ts", "package.json"]
		},

		"build": {
			"cache": true,
			"inputs": ["src/**", "tsdown.config.ts", "eslint.config.*", "tsconfig*.json", "package.json"],
			"outputs": ["dist/**"],
			"dependsOn": ["lint", "^build"]
		},

		"typecheck": {
			"cache": true,
			"dependsOn": ["^typecheck", "build"],
			"inputs": ["src/**", "tsconfig*.json"]
		},

		"test": {
			"cache": true,
			"inputs": ["src/**", "test/**", "vitest.config.*", "package.json"],
			"outputs": ["coverage/**", "*.xml"]
		},

		"watch": {
			"cache": false,
			"persistent": true
		},
		"cli": {
			"cache": false,
			"persistent": true,
			"interactive": true
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"interactive": true
		},
		"dev:debug": {
			"cache": false,
			"persistent": true,
			"interactive": true
		},
		"bun:dev": {
			"cache": false,
			"persistent": true,
			"interactive": true
		},
		"start": {
			"cache": false,
			"persistent": true
		},
		"format": {
			"cache": false
		},
		"format:check": {
			"cache": false
		},
		"clean": {
			"cache": false
		},
		"deep:clean": {
			"cache": false
		}
	}
}
