{
	"name": "@repo/db",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"clean": "rimraf dist .turbo",
		"watch:dev": "pnpm watch",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"format:check": "biome ci .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"watch": "tsc -p tsconfig.build.json --watch"
	},
	"exports": "./src/index.ts",
	"devDependencies": {
		"@types/pg": "catalog:",
		"eslint-config": "workspace:*",
		"typescript-config": "workspace:*"
	},
	"dependencies": {
		"drizzle-orm": "catalog:",
		"pg": "catalog:",
		"@repo/env": "workspace:*"
	},
	"startx": {
		"tags": [
			"node"
		],
		"requiredDeps": [
			"@repo/env"
		],
		"requiredDevDeps": [
			"typescript-config"
		]
	}
}
