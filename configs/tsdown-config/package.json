{
	"name": "tsdown-config",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": "./src/config/tsdown.base.ts",
	"scripts": {
		"clean": "rimraf dist",
		"deep:clean": "rimraf node_modules dist",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"format:check": "biome ci ."
	},
	"startx": {
		"gTags": [
			"tsdown"
		],
		"iTags": [
			"node"
		],
		"mode": "silent",
		"ignore": [
			"eslint-config",
			"typescript-config",
			"vitest-config"
		]
	}
}
