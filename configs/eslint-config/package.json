{
	"name": "eslint-config",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"exports": {
		"./base": "./src/configs/base.ts",
		"./frontend": "./src/configs/frontend.ts",
		"./node": "./src/configs/node.ts",
		"./extend": "./src/configs/extend.ts"
	},
	"scripts": {
		"lint": "eslint .",
		"lint:fix": "eslint . src/**/*.ts --fix",
		"clean": "rimraf dist .turbo dist",
		"deep:clean": "rimraf node_modules dist .turbo",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"format:check": "biome ci .",
		"test": "vitest run"
	},
	"dependencies": {
		"@eslint/compat": "catalog:",
		"@eslint/js": "catalog:",
		"@stylistic/eslint-plugin": "catalog:",
		"eslint-config-prettier": "catalog:",
		"eslint-import-resolver-typescript": "catalog:",
		"eslint-plugin-import-x": "catalog:",
		"eslint-plugin-jsx-a11y": "catalog:",
		"eslint-plugin-lodash": "catalog:",
		"eslint-plugin-react": "catalog:",
		"eslint-plugin-react-hooks": "catalog:",
		"eslint-plugin-unicorn": "catalog:",
		"eslint-plugin-unused-imports": "catalog:",
		"globals": "catalog:"
	},
	"devDependencies": {
		"@types/eslint-config-prettier": "catalog:",
		"@types/eslint-plugin-jsx-a11y": "catalog:",
		"@typescript-eslint/eslint-plugin": "catalog:",
		"@typescript-eslint/rule-tester": "catalog:",
		"@typescript-eslint/utils": "catalog:",
		"eslint": "catalog:",
		"typescript-config": "workspace:*",
		"typescript-eslint": "catalog:",
		"vitest-config": "workspace:*"
	},
	"startx": {
		"gTags": [
			"eslint"
		],
		"iTags": [
			"node"
		],
		"requiredDevDeps": [
			"typescript-config"
		],
		"ignore": [
			"eslint-config"
		]
	}
}
