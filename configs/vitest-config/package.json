{
	"name": "vitest-config",
	"version": "1.5.0",
	"type": "module",
	"devDependencies": {
		"jsdom": "^29.0.1",
		"typescript-config": "workspace:*",
		"vite": "catalog:",
		"vitest": "catalog:"
	},
	"exports": {
		".": "./src/index.ts",
		"./frontend": "./src/frontend.ts",
		"./node": "./src/node.ts",
		"./base": "./src/base.ts"
	},
	"scripts": {
		"clean": "rimraf dist .turbo",
		"deep:clean": "rimraf node_modules dist .turbo",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"format:check": "biome ci ."
	},
	"startx": {
		"gTags": [
			"vitest"
		],
		"iTags": [
			"node"
		],
		"requiredDevDeps": [
			"typescript-config"
		],
		"ignore": [
			"vitest-config",
			"eslint-config"
		]
	}
}
